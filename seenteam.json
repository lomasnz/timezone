
Nice — your JSON is clean enough to work with 👍 (mostly user directory export). The trick is: you don’t actually have explicit location fields, so you need to infer timezone from signals like phone numbers or known staff locations.

Step 1: Define your zone matching rules
Based on your zones list, here’s a practical mapping from your data:

+64 → Wellington (Pacific/Auckland)

+61 → Melbourne/Sydney (Australia/*) → you may need to choose one default

+66 → Bangkok (Asia/Bangkok)

+44 → Manchester (Europe/London)

+1 713 / Texas → Houston (America/Chicago)

+1 (general US fallback) → Denver (America/Denver) or Houston depending

Step 2: Build the transformation
Here’s a clean JS function that converts your uploaded JSON into what you want:

const zones = [
  { name: "Wellington", tz: "Pacific/Auckland" },
  { name: "Melbourne", tz: "Australia/Melbourne" },
  { name: "Sydney", tz: "Australia/Sydney" },
  { name: "Bangkok", tz: "Asia/Bangkok" },
  { name: "Manchester", tz: "Europe/London" },
  { name: "Houston", tz: "America/Chicago" },
  { name: "Denver", tz: "America/Denver" }
];

function detectZone(user) {
  const phone =
    user["Work Phone"] ||
    user["Mobile Phone"] ||
    user["Home Phone"] ||
    "";

  // NZ
  if (phone.startsWith("+64")) return "Wellington";

  // AU
  if (phone.startsWith("+61")) return "Sydney"; // or Melbourne if you prefer

  // Thailand
  if (phone.startsWith("+66")) return "Bangkok";

  // UK
  if (phone.startsWith("+44")) return "Manchester";

  // US (basic handling)
  if (phone.startsWith("+1")) {
    if (phone.includes("713")) return "Houston"; // Texas
    return "Denver"; // fallback US
  }

  return "Wellington"; // default fallback
}

const result = data.users.map(user => {
  const zoneName = detectZone(user);
  const zone = zones.find(z => z.name === zoneName);

  return {
    name: `${user["First Name [Required]"]} ${user["Last Name [Required]"]}`,
    tz: zone?.tz
  };
});

console.log(result);
